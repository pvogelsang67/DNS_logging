# The DNS-collector version to use. You can pin this to a specific version like "v0.40.0"
DNSCOLLECTOR_VERSION=v2.3.0-beta1

# The location where your DNS logs are stored
DNSCOLLECTOR_DATA=./data

# Variables for sending DNS data to Elasticsearch
#
ELASTIC_URL="http://127.0.0.1:9200"
ELASTIC_USER="elastic"
ELASTIC_PASS="elastic"
ELASTIC_IP="127.0.0.1"
ELASTIC_PORT="9200"
ELASTIC_PROTOCOL="http"